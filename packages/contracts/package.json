{
  "name": "@halo-protocol/contracts",
  "version": "1.0.0",
  "private": true,
  "description": "Halo Protocol smart contracts",
  "scripts": {
    "build": "forge build",
    "test": "forge test -vvv",
    "test:gas": "forge test --gas-report",
    "coverage": "forge coverage --report summary --report lcov",
    "lint": "forge fmt --check",
    "format": "forge fmt",
    "slither": "slither . --config-file slither.config.json",
    "deploy:testnet": "forge script script/DeployTestnet.s.sol --rpc-url $ARBITRUM_SEPOLIA_RPC --private-key $PRIVATE_KEY --broadcast --verify --etherscan-api-key $ARBISCAN_API_KEY",
    "deploy:mainnet": "forge script script/Deploy.s.sol --rpc-url $ARBITRUM_ONE_RPC --private-key $PRIVATE_KEY --broadcast --verify --etherscan-api-key $ARBISCAN_API_KEY",
    "clean": "forge clean",
    "install:deps": "forge install OpenZeppelin/openzeppelin-contracts@v5.2.0 --no-commit && forge install OpenZeppelin/openzeppelin-contracts-upgradeable@v5.2.0 --no-commit && forge install foundry-rs/forge-std --no-commit",
    "abi:export": "node scripts/export-abis.js"
  }
}
